<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hyperspace</title>

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style type="text/tailwindcss">
    @theme {
      --color-surface: #1a2332;
      --color-surface-light: #243447;
      --color-surface-lighter: #2d4055;
      --font-mono: 'JetBrains Mono', monospace;
    }
  </style>

  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

  <script src="/static/js/vendor/htmx.min.js"></script>
</head>

{# Color name to hex mapping #}
{% set colors = {"Cyan": "#22d3ee", "Purple": "#a78bfa", "Orange": "#fb923c", "Green": "#4ade80", "Pink": "#f472b6", "Yellow": "#facc15"} %}

<body class="bg-surface text-gray-200 font-mono h-screen overflow-hidden">

  <div id="app" class="relative w-full h-full">

    <div class="flex-1 relative overflow-hidden bg-surface select-none w-full h-full" id="grid-viewport">
      <div class="absolute top-[40%] left-1/2 -translate-x-1/2 -translate-y-1/2"
           style="perspective: 1000px">
        <div class="grid rotate-x-[60deg] -rotate-z-45 transform-3d"
             style="grid-template-columns: repeat({{ grid_size }}, 4rem); grid-template-rows: repeat({{ grid_size }}, 4rem)">

          {# Grid cells — click to create brick #}
          {% for row in range(grid_size) %}
            {% for col in range(grid_size) %}
            <form method="post" action="/brick"
                  style="grid-column: {{ col + 1 }}; grid-row: {{ row + 1 }}">
              <input type="hidden" name="x" value="{{ col }}">
              <input type="hidden" name="y" value="{{ row }}">
              <button type="submit"
                      class="size-16 border border-white/[0.04] bg-white/[0.015] cursor-pointer
                             transition-colors duration-150 hover:bg-cyan-400/[0.08] hover:border-cyan-400/15">
              </button>
            </form>
            {% endfor %}
          {% endfor %}

          {# Bricks #}
          {% set depth = 12 %}
          {% for brick in bricks %}
          {% set is_dragged = brick.dragged_by is not none %}
          <div id="block-{{ brick.id }}"
               class="group relative"
               style="grid-column: {{ brick.x + 1 }}; grid-row: {{ brick.y + 1 }};
                      --color: {{ colors[brick.color] }};
                      transform-style: preserve-3d;
                      transform: translateZ({{ brick.z * depth }}px);
                      z-index: {{ (brick.x + brick.y) * 10 + brick.z * 100 + 1 }}">
              {# Top face — click to delete #}
              <form method="post" action="/brick/{{ brick.id }}/delete"
                    class="size-16 border border-white/25 cursor-pointer
                           transition-[opacity,border-color] duration-150
                           starting:opacity-0 starting:scale-50
                           hover:border-red-400/70"
                    style="background: var(--color);
                           transform: translateZ({{ depth }}px)">
                <button type="submit" class="size-full"></button>
              </form>
              {# South wall #}
              <div class="absolute bottom-0 left-0 pointer-events-none border border-white/15
                          transition-[opacity,border-color] duration-150
                          starting:opacity-0"
                   style="width: 64px; height: {{ depth }}px;
                          background: color-mix(in srgb, var(--color) 65%, black);
                          transform-origin: bottom; transform: rotateX(-90deg)">
              </div>
              {# West wall #}
              <div class="absolute top-0 left-0 pointer-events-none border border-white/15
                          transition-[opacity,border-color] duration-150
                          starting:opacity-0"
                   style="width: {{ depth }}px; height: 64px;
                          background: color-mix(in srgb, var(--color) 45%, black);
                          transform-origin: left; transform: rotateY(-90deg)">
              </div>
          </div>
          {% endfor %}

        </div>
      </div>

      {# HUD overlay #}
      <div class="absolute top-4 left-5 pointer-events-none z-50 text-[10px] space-y-1 opacity-75">
        <div class="flex items-center gap-2">
          {% for user in users %}
            {% if user.online %}
            <div class="flex items-center gap-1">
              <span class="w-1.5 h-1.5 rounded-full" style="background: {{ colors[user.color] }}"></span>
              <span class="text-gray-300">{{ user.name }}</span>
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>

  {# Console #}
  <div id="console-log" class="absolute bottom-4 left-5 z-50 pointer-events-none
                                flex flex-col-reverse text-[10px] leading-relaxed space-y-px space-y-reverse max-h-26 overflow-hidden opacity-75">
    {% for event in events | reverse %}
    <div class="text-gray-400">{{ event.kind }}: user {{ event.user_id }}{% if event.brick_id %} brick {{ event.brick_id }}{% endif %}</div>
    {% endfor %}
  </div>

</body>
</html>
